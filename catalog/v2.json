      "get": {
        "description": "This endpoint is for search by item type ids.",
        "parameters": [
          {
            "in": "query",
            "name": "Taxonomy",
            "required": true,
            "type": "string"
          },
          {
            "collectionFormat": "multi",
            "in": "query",
            "items": {
              "format": "int32",
              "type": "integer"
            },
            "name": "AssetTypeIds",
            "required": true,
            "type": "array"
          },
          {
            "collectionFormat": "multi",
            "in": "query",
            "items": {
              "format": "int32",
              "type": "integer"
            },
            "name": "BundleTypeIds",
            "required": true,
            "type": "array"
          },
          {
            "enum": [
              0,
              1,
              2,
              3,
              4,
              5,
              6
            ],
            "format": "int32",
            "in": "query",
            "name": "CategoryFilter",
            "required": true,
            "type": "integer"
          },
          {
            "enum": [
              0,
              1,
              2,
              3,
              4,
              5
            ],
            "format": "int32",
            "in": "query",
            "name": "SortAggregation",
            "required": true,
            "type": "integer"
          },
          {
            "enum": [
              0,
              1,
              2,
              3,
              4,
              5
            ],
            "format": "int32",
            "in": "query",
            "name": "SortType",
            "required": true,
            "type": "integer"
          },
          {
            "enum": [
              0,
              1,
              2
            ],
            "format": "int32",
            "in": "query",
            "name": "CreatorType",
            "required": true,
            "type": "integer"
          },
          {
            "format": "int64",
            "in": "query",
            "name": "CreatorTargetId",
            "required": true,
            "type": "integer"
          },
          {
            "in": "query",
            "name": "CreatorName",
            "required": true,
            "type": "string"
          },
          {
            "format": "int32",
            "in": "query",
            "name": "MaxPrice",
            "required": true,
            "type": "integer"
          },
          {
            "format": "int32",
            "in": "query",
            "name": "MinPrice",
            "required": true,
            "type": "integer"
          },
          {
            "in": "query",
            "name": "Keyword",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "IncludeNotForSale",
            "required": true,
            "type": "boolean"
          },
          {
            "in": "query",
            "name": "TriggeredByTopicDiscovery",
            "required": true,
            "type": "boolean"
          },
          {
            "enum": [
              0,
              1,
              2,
              3,
              4
            ],
            "format": "int32",
            "in": "query",
            "name": "SalesTypeFilter",
            "required": true,
            "type": "integer"
          },
          {
            "description": "The input topics format is split by \",\". E.g \"topics=cat,hat,red\".",
            "in": "query",
            "name": "Topics",
            "required": true,
            "type": "string"
          },
          {
            "default": 10,
            "description": "The number of results per request.",
            "enum": [
              10,
              28,
              30,
              60,
              120
            ],
            "format": "int32",
            "in": "query",
            "name": "limit",
            "type": "integer"
          },
          {
            "description": "The paging cursor for the previous or next page.",
            "in": "query",
            "name": "cursor",
            "type": "string"
          },
          {
            "default": "Desc",
            "description": "The order the results are sorted in.",
            "enum": [
              "Desc"
            ],
            "in": "query",
            "name": "sortOrder",
            "type": "string"
          }
        ],
        "produces": [
          "application/json",
          "text/json"
        ],
        "properties": {
          "internal": false,
          "metricIds": [
            "SearchV2:SearchCatalogItemDetails"
          ]
        },
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/Roblox.Catalog.Api.CatalogSearchPageResponse[Roblox.Catalog.Api.CatalogSearchDetailedResponseItemV2]"
            }
          },
          "400": {
            "description": "1: Category subcategory selection not supported.\r\n2: Creator id not found.\r\n3: Creator type not found or cannot search by CreatorTargetId with CreatorType.All\r\n4: Genre not found.\r\n5: Sort combination not supported.\r\n6: Invalid price range.\r\n10: StartRequest is invalid."
          },
          "403": {
            "description": "7: User is unauthorized.\r\n22: In-experience search is denied for this place or universe."
          },
          "429": {
            "description": "8: The flood limit has been exceeded.\r\n8: The flood limit has been exceeded."
          },
          "503": {
            "description": "18: Search request timed out"
          }
        },
        "summary": "Search for catalog items.",
        "tags": [
          "SearchV2"
        ]
      }
    }
  },
  "schemes": [
    "https"
  ],
  "swagger": "2.0"
