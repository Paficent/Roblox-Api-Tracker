{
  "components": {
    "schemas": {
      "Error": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "format": "int32",
            "type": "integer"
          },
          "message": {
            "nullable": true,
            "type": "string"
          }
        },
        "type": "object"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "errors": {
            "items": {
              "$ref": "#/components/schemas/Error"
            },
            "nullable": true,
            "type": "array"
          }
        },
        "type": "object"
      },
      "PresenceType": {
        "enum": [
          0,
          1,
          2,
          3
        ],
        "format": "int32",
        "type": "integer"
      },
      "UserPresence": {
        "additionalProperties": false,
        "properties": {
          "gameId": {
            "format": "uuid",
            "nullable": true,
            "type": "string"
          },
          "lastLocation": {
            "nullable": true,
            "type": "string"
          },
          "placeId": {
            "format": "int64",
            "nullable": true,
            "type": "integer"
          },
          "rootPlaceId": {
            "format": "int64",
            "nullable": true,
            "type": "integer"
          },
          "universeId": {
            "format": "int64",
            "nullable": true,
            "type": "integer"
          },
          "userId": {
            "format": "int64",
            "type": "integer"
          },
          "userPresenceType": {
            "allOf": [
              {
                "$ref": "#/components/schemas/PresenceType"
              }
            ]
          }
        },
        "type": "object"
      },
      "UserPresenceRequest": {
        "additionalProperties": false,
        "properties": {
          "userIds": {
            "items": {
              "format": "int64",
              "type": "integer"
            },
            "nullable": true,
            "type": "array"
          }
        },
        "type": "object"
      },
      "UserPresencesResponse": {
        "additionalProperties": false,
        "properties": {
          "userPresences": {
            "items": {
              "$ref": "#/components/schemas/UserPresence"
            },
            "nullable": true,
            "type": "array"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "title": "presence-api",
    "version": "v1"
  },
  "openapi": "3.0.1",
  "paths": {
    "/v1/presence/users": {
      "post": {
        "operationId": "Presence_GetUserPresences",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/UserPresenceRequest"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserPresencesResponse"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Bad Request"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Forbidden"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Too Many Requests"
          }
        },
        "tags": [
          "Presence"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "https://presence.roblox.com"
    }
  ]
}